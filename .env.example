# scalematic-agents configuration — KEY NAMES ONLY. Never commit real values.
# Copy to .env and fill in. .env is git-ignored.

# Runtime
PORT=3100
# Absolute path to the Obsidian vault root. If unset, falls back to the configured
# default vault root. Never expose this absolute path to browser clients.
VAULT_ROOT=
# CORS allowlist (comma-separated). Production dashboard origin + local dev origin.
ALLOWED_ORIGIN=http://localhost:4100

# Reasoning runtime (Anthropic). A present key means configured, not verified-live.
ANTHROPIC_API_KEY=
# Set to "true" to force the reasoning runtime to report blocked.
ANTHROPIC_DISABLED=

# FMCSA prospect sentinel
FMCSA_PROVIDER=

# Outbound email (Instantly). Live sends gated by LIVE_SENDS.
INSTANTLY_API_KEY=
LIVE_SENDS=

# GoHighLevel
GHL_API_KEY=
GHL_BASE_URL=
GHL_LOCATION_ID=

# Unipile (LinkedIn)
UNIPILE_API_KEY=
UNIPILE_BASE_URL=

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_APPROVAL_CHANNEL=

# OpenAI (optional)
OPENAI_API_KEY=
